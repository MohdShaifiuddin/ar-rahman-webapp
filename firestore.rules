rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - The unique identifier for the user.
    //   - email: string (required, email format) - The user's email address.
    //   - displayName: string (optional) - The user's display name.
    //   - role: string (required, enum: student, teacher, admin) - The user's role.
    //   - enrolledCourses: list (optional) - List of course IDs.
    //   - emailPreferences: map (optional) - User's email notification preferences.
    //     - reminders: bool
    //     - announcements: bool
    //
    // Collection: progress
    // Document ID: progressId (studentId_courseId)
    // Fields:
    //   - studentId: string (required) - The UID of the student.
    //   - courseId: string (required) - The ID of the course.
    //   - completedModules: list (required) - List of completed module IDs.
    //   - lastUpdated: timestamp (optional) - The last time the progress was updated.
    //
    // Collection: communications
    // Document ID: auto-generated
    // Fields:
    //   - senderId: string (required) - The UID of the admin sender.
    //   - message: string (required) - The content of the communication.
    //   - recipients: list (required) - List of recipient UIDs.
    //   - timestamp: string (required, ISO 8601) - The time the message was sent.
    //   - type: string (required, e.g., 'bulk') - The type of communication.
    //
    // Collection: reminders
    // Document ID: auto-generated
    // Fields:
    //   - studentId: string (required) - The UID of the student.
    //   - courseId: string (required) - The ID of the course.
    //   - moduleId: string (required) - The ID of the module.
    //   - reminderTime: string (required, ISO 8601) - The scheduled time.
    //   - message: string (optional) - Optional reminder message.
    //   - isNotified: bool (optional) - Whether the user has been notified.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (hasRole('admin') ||
         (request.auth.token.email == "mohdshafiuddinthg@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isStaff() {
      return isAdmin() || isTeacher();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['student', 'teacher', 'admin'];
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['studentId', 'courseId', 'completedModules']) &&
             data.studentId is string && data.studentId.size() > 0 &&
             data.courseId is string && data.courseId.size() > 0 &&
             data.completedModules is list && data.completedModules.size() <= 100;
    }

    function isValidCommunication(data) {
      return data.keys().hasAll(['senderId', 'message', 'recipients', 'timestamp', 'type']) &&
             data.senderId is string &&
             data.message is string && data.message.size() > 0 && data.message.size() < 5000 &&
             data.recipients is list && data.recipients.size() <= 1000 &&
             data.timestamp is string &&
             data.type is string;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['studentId', 'courseId', 'moduleId', 'reminderTime']) &&
             data.studentId is string &&
             data.courseId is string &&
             data.moduleId is string &&
             data.reminderTime is string;
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['courseId', 'title', 'description', 'dueDate', 'teacherId', 'createdAt']) &&
             data.courseId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.dueDate is string &&
             data.teacherId is string &&
             data.createdAt is string;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['assignmentId', 'studentId', 'content', 'submittedAt', 'status']) &&
             data.assignmentId is string &&
             data.studentId is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.submittedAt is string &&
             data.status in ['pending', 'reviewed'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'student' || isAdmin());
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /progress/{progressId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isStaff());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.studentId) || isStaff()) && isValidProgress(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data.studentId) || isStaff()) && isValidProgress(request.resource.data);
    }

    match /communications/{commId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.recipients || isStaff());
      allow create: if isAdmin() && isValidCommunication(request.resource.data);
    }

    match /reminders/{reminderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.studentId) && isValidReminder(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.studentId) && isValidReminder(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.studentId);
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isStaff() && isValidAssignment(request.resource.data);
      allow update: if isStaff() && isValidAssignment(request.resource.data);
      allow delete: if isStaff();
    }

    match /submissions/{submissionId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isStaff());
      allow create: if isAuthenticated() && isOwner(request.resource.data.studentId) && isValidSubmission(request.resource.data);
      allow update: if isAuthenticated() && (isStaff() || (isOwner(resource.data.studentId) && resource.data.status == 'pending')) && isValidSubmission(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data.studentId) && resource.data.status == 'pending');
    }
  }
}
